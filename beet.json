{
    "name": "Tables & Chairs 2",
    "description": "Modular, functional and customisable Tables & Chairs for your game of Minecraft. Originally based on Axel's Tables & Chairs!",
    "require":[
        "bolt"
    ],

    "data_pack":{
        "load":["src"],
        "min_format": [82],
        "max_format": [107,1],
        "overlays": [
            {
                "min_format": [82],
                "max_format": [101,1],
                "directory": "tac_upto26-1"
            }
        ]
    },
    "resource_pack":{
        "load":["src"],
        "min_format": [65],
        "max_format": [88]
    },
    
    "output": "build",
    "pipeline":[
        "mecha",
        "assets.generate"
    ],
    "meta": {
        "wood_types": ["acacia", "bamboo", "birch", "cherry", "crimson", "dark_oak", "jungle", "mangrove", "oak", "pale_oak", "spruce", "warped"],
        "mineral_types": ["quartz", "stone_brick", "obsidian", "netherite", "iron", "gold", "diamond", "copper"]
    }
}